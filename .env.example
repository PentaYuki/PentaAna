# .env mẫu cho Stock-AI

# ── Chọn broker ─────────────────────────────
BROKER=paper          # paper | vndirect | ssi

# ── Cấu hình Paper Broker (test an toàn) ───
PAPER_CAPITAL=500000000         # 500 triệu VND giả lập

# ── Cấu hình VNDirect (giao dịch thật) ────
# VNDIRECT_ACCOUNT=000C123456
# VNDIRECT_CONSUMER_ID=your_consumer_id
# VNDIRECT_PRIVATE_KEY=base64_encoded_pem_private_key
# VNDIRECT_ENV=sandbox            # sandbox trước, prod sau

# ── Cấu hình SSI (nếu dùng SSI) ───────────
# SSI_CLIENT_ID=your_client_id
# SSI_CLIENT_SECRET=your_client_secret
# SSI_ACCOUNT=your_account_number
# SSI_PIN=your_pin

# ── Giới hạn rủi ro ───────────────────────
MAX_POSITION_VND=50000000       # Tối đa 50 triệu/lệnh
MAX_DAILY_ORDERS=5              # Tối đa 5 lệnh/ngày
